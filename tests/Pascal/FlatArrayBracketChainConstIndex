program FlatArrayBracketChainConstIndex;

{ Regression test: bracket-chain access with all-constant indices into a
  genuinely flat (non-jagged) multi-dimensional static array, e.g. f[1][2]
  on array[1..2, 1..3] of integer, used to mis-fold the first bracket into
  a scalar constant offset and crash/error on the second bracket. }

type
  Flat = array[1..2, 1..3] of integer;
  Cube = array[1..2, 1..2, 1..2] of integer;

var
  f: Flat;
  c: Cube;

procedure AssertEqualInt(expected, actual: integer; testName: string);
begin
  write('START: ', testName, ': ');
  if expected = actual then
    writeln('PASS')
  else
    writeln('FAIL (expected: ', expected, ', got: ', actual, ')');
end;

begin
  { Store via bracket-chain, all-constant indices. }
  f[1][2] := 5;
  AssertEqualInt(5, f[1][2], 'Bracket-chain store/load f[1][2]');
  AssertEqualInt(5, f[1, 2], 'Bracket-chain store matches comma-syntax read f[1,2]');

  { Exercise every cell via bracket-chain and cross-check against comma syntax. }
  f[1][1] := 10;
  f[1][3] := 30;
  f[2][1] := 40;
  f[2][2] := 50;
  f[2][3] := 60;
  AssertEqualInt(f[1, 1], f[1][1], '2D bracket-chain matches comma f[1][1]');
  AssertEqualInt(f[1, 3], f[1][3], '2D bracket-chain matches comma f[1][3]');
  AssertEqualInt(f[2, 1], f[2][1], '2D bracket-chain matches comma f[2][1]');
  AssertEqualInt(f[2, 2], f[2][2], '2D bracket-chain matches comma f[2][2]');
  AssertEqualInt(f[2, 3], f[2][3], '2D bracket-chain matches comma f[2][3]');

  { Same shape, 3 dimensions, chain split across multiple brackets. }
  c[1][2][1] := 111;
  AssertEqualInt(111, c[1, 2, 1], '3D bracket-chain store matches comma c[1,2,1]');
  c[2, 1, 2] := 222;
  AssertEqualInt(222, c[2][1][2], '3D comma store matches bracket-chain read c[2][1][2]');

  writeln('FlatArrayBracketChainConstIndex Completed.');
end.
